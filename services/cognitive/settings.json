{
  "process": {
    "role": "worker"
  },
  "role": {
    "profile": "cognitive"
  },
  "transport": {
    "url": "amqp://rabbitmq:5672",
    "vhost": "legionio"
  },
  "cache": {
    "driver": "redis",
    "url": "redis://redis:6379/0"
  },
  "data": {
    "adapter": "postgres",
    "host": "postgresql",
    "port": 5432,
    "database": "legionio",
    "pool_size": 10
  },
  "logging": {
    "level": "info",
    "json": true
  },
  "api": {
    "enabled": false
  },
  "gaia": {
    "enabled": true
  }
}
