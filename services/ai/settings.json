{
  "process": {
    "role": "worker"
  },
  "role": {
    "profile": "custom",
    "extensions": [
      "codegen", "conditioner", "exec", "health", "lex", "llm-gateway",
      "log", "metering", "node", "ping", "scheduler", "tasker",
      "task_pruner", "telemetry", "transformer",
      "azure-ai", "bedrock", "claude", "foundry", "gemini", "openai", "xai",
      "eval", "prompt"
    ]
  },
  "transport": {
    "url": "amqp://rabbitmq:5672",
    "vhost": "legionio"
  },
  "cache": {
    "driver": "redis",
    "url": "redis://redis:6379/0"
  },
  "data": {
    "adapter": "postgres",
    "host": "postgresql",
    "port": 5432,
    "database": "legionio",
    "pool_size": 10
  },
  "logging": {
    "level": "info",
    "json": true
  },
  "api": {
    "enabled": false
  },
  "llm": {
    "pipeline_enabled": true
  }
}
